# PostgreSQL
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_pass
POSTGRES_DB=ecommerce_raw
POSTGRES_HOST=postgres
POSTGRES_PORT=5433


# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://ecommerce_user:ecommerce_pass@postgres:5432/ecommerce_raw
AIRFLOW__CORE__FERNET_KEY=YOUR_FERNET_KEY_HERE
AIRFLOW__WEBSERVER__SECRET_KEY=YOUR_SECRET_KEY_HERE

# DuckDB
DUCKDB_PATH=/opt/airflow/data/warehouse.duckdb

# Paths
DATA_OUTPUT_PATH=/opt/airflow/data
